{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.swarnandhra.ac.in/visionx/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/visionx/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/visionx/:path*",
      "destination": "/index.html"
    }
  ]
}
